{
  "expo": {
    "name": "شام باي",
    "slug": "marketplace-mobile",
    "version": "1.0.0",
    "scheme": "shambay",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/app-icon/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shambay.marketplace",
      "appleTeamId": "M425KFPB9Z",
      "buildNumber": "11",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "نحتاج إلى موقعك لإنشاء رابط خريطة Google لإعلانك",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon/splash-icon.png",
        "backgroundColor": "#3D5CB6"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "versionCode": 5,
      "package": "com.shambay.marketplace",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/images/app-icon/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "نحتاج إلى موقعك لإنشاء رابط خريطة Google لإعلانك"
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon/icon.png",
          "color": "#3D5CB6",
          "defaultChannel": "default",
          "useNextNotificationsApi": true
        }
      ],
      "@react-native-google-signin/google-signin",
      "@maplibre/maplibre-react-native"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a79aa2ea-7a71-4cc2-8295-d2e4f525d9f4"
      },
      "privacyUrl": "https://shambay.com/privacy",
      "termsUrl": "https://shambay.com/terms"
    },
    "owner": "shambay"
  }
}
